# Production Environment Configuration
# Copy this file to .env.production and modify as needed

# ==============================================
# 🔒 SECURITY SETTINGS (CHANGE ALL PASSWORDS!)
# ==============================================

# Database Configuration
DB_ROOT_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_123!
DB_NAME=erpnext_prod
DB_USER=erpnext
DB_PASSWORD=CHANGE_THIS_DB_PASSWORD_456!

# ERPNext Configuration  
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD_789!
SITE_NAME=your-domain.com
FRAPPE_ENV=production

# ==============================================
# 🌐 NETWORK & DOMAIN SETTINGS
# ==============================================

# Domain Configuration
DOMAIN=your-domain.com
SUBDOMAIN=www.your-domain.com

# SSL Configuration
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

# ==============================================
# 📧 EMAIL CONFIGURATION
# ==============================================

# SMTP Settings (Gmail example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_LOGIN=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# ==============================================
# 💾 BACKUP CONFIGURATION
# ==============================================

# Backup Settings
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=/opt/erpnext-backups
S3_BACKUP_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ==============================================
# 🔧 PERFORMANCE SETTINGS
# ==============================================

# Redis Configuration
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Database Performance
MYSQL_INNODB_BUFFER_POOL_SIZE=1G
MYSQL_INNODB_LOG_FILE_SIZE=256M
MYSQL_MAX_CONNECTIONS=200

# ==============================================
# 📊 MONITORING & LOGGING
# ==============================================

# Logging
LOG_LEVEL=INFO
LOG_MAX_SIZE=100m
LOG_MAX_FILES=5

# Monitoring
ENABLE_MONITORING=true
GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD!

# ==============================================
# 🛡️ SECURITY HEADERS
# ==============================================

# Security Settings
ENABLE_HSTS=true
ENABLE_CSP=true
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# ==============================================
# 🚀 DEPLOYMENT SETTINGS
# ==============================================

# Deployment Mode
DEPLOYMENT_MODE=production
DEBUG=false
DEVELOPER_MODE=0

# Scaling
WORKER_PROCESSES=2
WORKER_CONNECTIONS=1000
